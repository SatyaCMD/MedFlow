# API Configuration
PORT=4000
NODE_ENV=development

# Database Connections
MONGO_URI=mongodb://localhost:27017/medicore

# Redis Configuration
REDIS_URI=redis://localhost:6379

# Auth Keys
JWT_ACCESS_SECRET=your_jwt_access_secret_key_32_chars
